<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:layout_marginBottom="@dimen/spacing_xxl"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivAppLogo"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="@string/dashboard_title"
                android:textColor="@color/colorTextPrimary"
                android:textSize="@dimen/text_title"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/dashboard_subtitle"
                android:textColor="@color/colorTextSecondary"
                android:textSize="@dimen/text_subtitle" />
        </LinearLayout>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <!-- Registered Count -->
            <LinearLayout
                android:id="@+id/totalRegisteredCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_weight="1"
                android:background="@drawable/gradient_background"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:id="@+id/tvRegisteredCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_stat"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/total_registered"
                    android:textColor="#B3FFFFFF"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>

            <!-- Today's Attendance Count -->
            <LinearLayout
                android:id="@+id/allRecordsCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                android:background="@drawable/gradient_background"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:id="@+id/tvTodayCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_stat"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/today_attendance"
                    android:textColor="#B3FFFFFF"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>
        </LinearLayout>

        <!-- Register Face Card -->
        <LinearLayout
            android:id="@+id/cardRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:background="@drawable/card_background"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/card_padding">

            <View
                android:layout_width="4dp"
                android:layout_height="48dp"
                android:layout_marginEnd="@dimen/spacing_md"
                android:background="@color/cardRegister" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_face"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_heading"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/register_face_desc"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/text_body" />
            </LinearLayout>

        </LinearLayout>

        <!-- Take Attendance Card -->
        <LinearLayout
            android:id="@+id/cardAttendance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:background="@drawable/card_background"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/card_padding">

            <View
                android:layout_width="4dp"
                android:layout_height="48dp"
                android:layout_marginEnd="@dimen/spacing_md"
                android:background="@color/cardAttendance" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/take_attendance"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_heading"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/take_attendance_desc"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/text_body" />
            </LinearLayout>

        </LinearLayout>

        <!-- View Records Card -->
        <LinearLayout
            android:id="@+id/cardRecords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:background="@drawable/card_background"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/card_padding">

            <View
                android:layout_width="4dp"
                android:layout_height="48dp"
                android:layout_marginEnd="@dimen/spacing_md"
                android:background="@color/cardRecords" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_records"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_heading"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/view_records_desc"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/text_body" />
            </LinearLayout>

        </LinearLayout>

        <!-- Registered Users Card -->
        <LinearLayout
            android:id="@+id/cardUsers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:background="@drawable/card_background"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/card_padding">

            <View
                android:layout_width="4dp"
                android:layout_height="48dp"
                android:layout_marginEnd="@dimen/spacing_md"
                android:background="@color/cardUsers" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/registered_users"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_heading"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/registered_users_desc"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/text_body" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>