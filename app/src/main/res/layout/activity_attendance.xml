<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".ui.AttendanceActivity">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Face Overlay -->
    <com.example.aiattendancesystem.ui.FaceOverlayView
        android:id="@+id/faceOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#80000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="@dimen/icon_size_md"
            android:layout_height="@dimen/icon_size_md"
            android:clickable="true"
            android:contentDescription="Back"
            android:focusable="true"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:text="@string/attendance_title"
            android:textColor="@color/white"
            android:textSize="@dimen/text_heading"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnSwitchCamera"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_button"
            android:clickable="true"
            android:contentDescription="@string/switch_camera"
            android:focusable="true"
            android:padding="10dp"
            android:src="@drawable/ic_camera_switch"
            app:tint="@color/white" />
    </LinearLayout>

    <!-- Bottom Status Panel -->
    <LinearLayout
        android:id="@+id/statusPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC1A1F36"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvRecognizedName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scanning"
            android:textColor="@color/colorTextPrimary"
            android:textSize="@dimen/text_heading"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRecognitionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="@string/scanning"
            android:textColor="@color/colorTextSecondary"
            android:textSize="@dimen/text_body" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCapture"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="Capture &amp; Recognize"
            android:textAllCaps="false"
            android:textSize="@dimen/text_subtitle"
            android:textStyle="bold"
            app:backgroundTint="@color/colorAccent"
            app:cornerRadius="@dimen/button_corner_radius"
            app:icon="@drawable/ic_camera"
            app:iconGravity="textStart"
            app:iconTint="@color/white" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
